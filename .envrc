#!/bin/bash

# Pular init em shells não-interativas (Claude Code Bash tool, scripts, CI).
# Sem isso, cada comando disparava init + trap EXIT + fim-sessao.sh = commit loop.
if [ ! -t 1 ]; then
  exit 0
fi

echo ""
echo "⚔️  Excalibur HQ — Inicializando..."

# Matar auto-save anterior
if [ -f .auto-save.pid ]; then
  kill $(cat .auto-save.pid) 2>/dev/null
  rm .auto-save.pid
fi

# Auto-save a cada 5 minutos em background
(
  while true; do
    sleep 300
    cd ~/Desktop/excalibur/excalibur-hq
    if ! git diff --quiet 2>/dev/null || ! git diff --staged --quiet 2>/dev/null; then
      DATE=$(date '+%H:%M')
      git add -A --quiet
      git commit -m "auto-save: $DATE" --quiet 2>/dev/null
      git push --quiet 2>/dev/null
      echo "💾 Auto-save: $DATE"
    fi
  done
) &
echo $! > .auto-save.pid

# Status
echo "✅ Auto-save ativo (5 min)"
echo "📊 $(git log --oneline -1 2>/dev/null)"
echo "🌐 excalibur-hq.vercel.app"
echo "📚 $(ls docs/critico/ 2>/dev/null | wc -l | tr -d ' ') docs técnicos"
echo "⚔️  Pronto!"
echo ""

# REMOVIDO: trap '...fim-sessao.sh' EXIT
# Motivo: .envrc roda via `bash .envrc` (subshell), então o EXIT disparava
# imediatamente ao fim do script, não ao fechar o terminal — criando commits
# fantasma a cada `cd`. Para encerrar sessão, usar o alias `hq-fim`.
